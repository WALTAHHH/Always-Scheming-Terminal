{
  "openapi": "3.1.0",
  "info": {
    "title": "Always Scheming Terminal API",
    "version": "1.0.0",
    "description": "OpenAPI specification for AST API v1 endpoints. Last verified: 2026-07-24"
  },
  "servers": [
    {
      "url": "/api/v1",
      "description": "Relative to base URL"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "timestamp": {
                      "type": "string",
                      "format": "date-time"
                    },
                    "build": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "ok",
                    "timestamp",
                    "build"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/signals": {
      "get": {
        "summary": "List signals",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "description": "Maximum number of signals to return (max 200)",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 50,
              "minimum": 1,
              "maximum": 200
            }
          },
          {
            "name": "min_score",
            "in": "query",
            "description": "Minimum investment relevance score",
            "required": false,
            "schema": {
              "type": "number",
              "format": "float",
              "default": 0.3
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of signals",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "signals": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Signal"
                      }
                    },
                    "count": {
                      "type": "integer"
                    }
                  },
                  "required": [
                    "signals",
                    "count"
                  ]
                }
              }
            }
          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/entities": {
      "get": {
        "summary": "List entities or lookup by alias",
        "parameters": [
          {
            "name": "alias",
            "in": "query",
            "description": "Lookup entity by alias or canonical name (case-insensitive). If provided, auth is optional.",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "entity_type",
            "in": "query",
            "description": "Filter by entity type (e.g., 'company', 'person')",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Page size for listing",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 100,
              "minimum": 1
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "description": "Pagination cursor (canonical_name)",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "security": [
          {
            "apiKey": []
          }
        ],
        "responses": {
          "200": {
            "description": "Entity lookup result or list",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/Entity"
                        }
                      },
                      "required": [
                        "data"
                      ]
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/Entity"
                          }
                        },
                        "count": {
                          "type": "integer"
                        },
                        "next_cursor": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "data",
                        "count",
                        "next_cursor"
                      ]
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/sources": {
      "get": {
        "summary": "List active sources",
        "security": [
          {
            "apiKey": []
          }
        ],
        "responses": {
          "200": {
            "description": "List of sources",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Source"
                      }
                    },
                    "count": {
                      "type": "integer"
                    }
                  },
                  "required": [
                    "data",
                    "count"
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/items": {
      "get": {
        "summary": "List content items",
        "security": [
          {
            "apiKey": []
          }
        ],
        "parameters": [
          {
            "name": "source_id",
            "in": "query",
            "description": "Filter by source ID",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "signal_type",
            "in": "query",
            "description": "Filter by signal type",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "date_from",
            "in": "query",
            "description": "Filter by published date (ISO 8601)",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "date_to",
            "in": "query",
            "description": "Filter by published date (ISO 8601)",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Page size",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 50,
              "minimum": 1
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "description": "Pagination cursor (published_at)",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of items",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Item"
                      }
                    },
                    "count": {
                      "type": "integer"
                    },
                    "next_cursor": {
                      "type": "string",
                      "format": "date-time"
                    }
                  },
                  "required": [
                    "data",
                    "count",
                    "next_cursor"
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/entity-aliases": {
      "get": {
        "summary": "Get alias map or search entities",
        "parameters": [
          {
            "name": "search",
            "in": "query",
            "description": "Search prefix for entity canonical names (autocomplete)",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Alias map or search results",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    {
                      "type": "object",
                      "properties": {
                        "results": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          }
                        }
                      },
                      "required": [
                        "results"
                      ]
                    },
                    {
                      "type": "object",
                      "properties": {
                        "aliases": {
                          "type": "object",
                          "additionalProperties": {
                            "type": "string"
                          }
                        }
                      },
                      "required": [
                        "aliases"
                      ]
                    }
                  ]
                }
              }
            }
          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create a new entity alias (admin)",
        "security": [
          {
            "apiKey": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "alias": {
                    "type": "string"
                  },
                  "canonical_name": {
                    "type": "string"
                  }
                },
                "required": [
                  "alias",
                  "canonical_name"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Alias created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "alias": {
                      "type": "string"
                    },
                    "entity": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "ok",
                    "alias",
                    "entity"
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "404": {
            "description": "Entity not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "409": {
            "description": "Alias already exists",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          }
        },
        "required": [
          "error"
        ]
      },
      "Signal": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "signal_type": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "investment_relevance_score": {
            "type": "number",
            "format": "float"
          },
          "companies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "title": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "published_at": {
            "type": "string",
            "format": "date-time"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "signal_type",
          "summary",
          "investment_relevance_score",
          "companies",
          "title",
          "url",
          "published_at",
          "created_at"
        ]
      },
      "EntityAlias": {
        "type": "object",
        "properties": {
          "alias": {
            "type": "string"
          },
          "alias_type": {
            "type": "string"
          }
        },
        "required": [
          "alias",
          "alias_type"
        ]
      },
      "Entity": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "canonical_name": {
            "type": "string"
          },
          "entity_type": {
            "type": "string"
          },
          "ticker": {
            "type": "string"
          },
          "exchange": {
            "type": "string"
          },
          "is_public": {
            "type": "boolean"
          },
          "parent_id": {
            "type": "integer",
            "format": "int64"
          },
          "description": {
            "type": "string"
          },
          "ir_url": {
            "type": "string"
          },
          "sec_url": {
            "type": "string"
          },
          "segment": {
            "type": "string"
          },
          "market_cap_b": {
            "type": "number",
            "format": "float"
          },
          "entity_aliases": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EntityAlias"
            }
          }
        },
        "required": [
          "id",
          "canonical_name",
          "entity_type",
          "ticker",
          "exchange",
          "is_public",
          "parent_id",
          "description",
          "ir_url",
          "sec_url",
          "segment",
          "market_cap_b",
          "entity_aliases"
        ]
      },
      "Source": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "name": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "source_type": {
            "type": "string"
          },
          "active": {
            "type": "boolean"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "name",
          "url",
          "source_type",
          "active",
          "created_at",
          "updated_at"
        ]
      },
      "ContentTag": {
        "type": "object",
        "properties": {
          "dimension": {
            "type": "string"
          },
          "value": {
            "type": "string"
          },
          "entity_id": {
            "type": "integer",
            "format": "int64"
          }
        },
        "required": [
          "dimension",
          "value",
          "entity_id"
        ]
      },
      "ItemSignal": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "signal_type": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "investment_relevance_score": {
            "type": "number",
            "format": "float"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "signal_type",
          "summary",
          "investment_relevance_score",
          "created_at"
        ]
      },
      "Item": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "title": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "body": {
            "type": "string"
          },
          "author": {
            "type": "string"
          },
          "published_at": {
            "type": "string",
            "format": "date-time"
          },
          "ingested_at": {
            "type": "string",
            "format": "date-time"
          },
          "source_id": {
            "type": "integer",
            "format": "int64"
          },
          "sources": {
            "$ref": "#/components/schemas/Source"
          },
          "content_tags": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ContentTag"
            }
          },
          "signals": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ItemSignal"
            }
          }
        },
        "required": [
          "id",
          "title",
          "url",
          "body",
          "author",
          "published_at",
          "ingested_at",
          "source_id",
          "sources",
          "content_tags",
          "signals"
        ]
      }
    },
    "securitySchemes": {
      "apiKey": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "API key"
      }
    }
  },
  "security": []
}